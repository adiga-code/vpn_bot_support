# Auth — сгенерируй свой: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_random_hex_64_chars

# Первый администратор (создаётся автоматически при первом запуске, если операторов нет)
# После создания эти переменные можно убрать
ADMIN_INIT_TG=@your_tg_username
ADMIN_INIT_PASSWORD=change_me

# Redis
REDIS_URL=redis://redis:6379

# PostgreSQL
POSTGRES_DB=vpnbot
POSTGRES_USER=vpnbot
POSTGRES_PASSWORD=your_password_here

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8000

# AI провайдер для чата (classification, KB-чанкинг)
# "openai" (по умолчанию) или "gemini"
CHAT_PROVIDER=openai

# OpenAI — обязателен для эмбеддингов KB; также используется для чата при CHAT_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Gemini — заполнить если CHAT_PROVIDER=gemini (эмбеддинги всё равно через OpenAI)
GEMINI_API_KEY=

# Qdrant — векторная БД (по умолчанию из docker-compose)
QDRANT_URL=http://qdrant:6333

# Billing API (оставь пустым — будет использоваться заглушка)
BILLING_API_URL=
BILLING_API_TOKEN=

# Server monitoring: "tcp" | "http" | "stub"
SERVERS_MONITOR_TYPE=tcp
SERVERS_CHECK_INTERVAL=300
SERVERS_HEALTH_PATH=/health
# JSON-список серверов (host — IP или hostname, port — для TCP/HTTP проверки)
SERVERS=[{"name":"Frankfurt-01","host":"1.2.3.4","port":443,"location":"DE"},{"name":"Amsterdam-03","host":"5.6.7.8","port":443,"location":"NL"}]

      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [880, 200]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst out = {\n  dialog_id: d.dialog_id,\n  chat_id: String(d.chat_id),\n  message: d.message || ''\n};\nif (d.file_url) {\n  out.file_id = d.file_url;\n  out.file_type = d.file_type || 'document';\n} else if (d.file_id) {\n  out.file_id = d.file_id;\n  out.file_type = d.file_type || 'document';\n}\nreturn [{ json: out }];"
      },

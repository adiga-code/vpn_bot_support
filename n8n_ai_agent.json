    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.history || [];\nconst list = Array.isArray(raw) ? raw : [raw];\nconst parsed = list.map((e) => {\n  try { return typeof e === \"string\" ? JSON.parse(e) : e; }\n  catch (err) { return { role: \"user\", content: String(e) }; }\n});\nconst recent = parsed.slice(-10);\n// Убираем фигурные скобки: историю подставляем в шаблон промпта гейта,\n// где { } трактуются как переменные шаблона и могут сломать разбор.\nconst clean = (s) => String(s || \"\").replace(/[{}]/g, \"\");\nconst lines = recent.map((o) => (o.role === \"assistant\" ? \"Ассистент: \" : \"Пользователь: \") + clean(o.content));\n// «Набор шагов» = ответ ассистента с двумя и более нумерованными строками,\n// исключая вступительную анкету (она содержит вопрос про приложение).\nconst isStepList = (o) =>\n  o.role === \"assistant\" &&\n  ((o.content || \"\").match(/(^|\\n)\\s*\\d+[.)]/g) || []).length >= 2 &&\n  !(o.content || \"\").includes(\"Через какое приложение\");\nconst stepListCount = parsed.filter(isStepList).length;\nreturn [{ json: { ...$json, historyText: lines.join(\"\\n\"), stepListCount } }];"
      },

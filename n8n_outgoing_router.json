      "name": "Отправить текст пользователю",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [1540, 330]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst event = d.event;\nconst texts = {\n  new_dialog:      () => `📩 Новый диалог\\nПользователь: ${d.username || d.dialog_id}`,\n  operator_called: () => `🆘 Вызов оператора\\nПользователь: ${d.username || d.dialog_id}`,\n  dialog_closed:   () => `✅ Диалог закрыт\\nОператор: ${d.operator_name || '—'}\\nID: ${d.dialog_id}`,\n  ai_toggled:      () => `🤖 ИИ ${d.ai_enabled ? 'включён ✅' : 'выключен ❌'}\\nДиалог: ${d.dialog_id}`,\n  server_down:     () => `🔴 Сервер vpn_bot недоступен!`,\n};\nconst text = texts[event] ? texts[event]() : `[${event}] ${JSON.stringify(d)}`;\nreturn [{ json: { text } }];"
      },
      "id": "00000000-000c-4000-8000-00000000000c",

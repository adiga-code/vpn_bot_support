# Redis
REDIS_URL=redis://redis:6379

# PostgreSQL
POSTGRES_DB=vpnbot
POSTGRES_USER=vpnbot
POSTGRES_PASSWORD=your_password_here

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Billing API (оставь пустым — будет использоваться заглушка)
BILLING_API_URL=
BILLING_API_TOKEN=

# Server monitoring: "tcp" | "http" | "stub"
SERVERS_MONITOR_TYPE=tcp
SERVERS_CHECK_INTERVAL=300
SERVERS_HEALTH_PATH=/health
# JSON-список серверов (host — IP или hostname, port — для TCP/HTTP проверки)
SERVERS=[{"name":"Frankfurt-01","host":"1.2.3.4","port":443,"location":"DE"},{"name":"Amsterdam-03","host":"5.6.7.8","port":443,"location":"NL"}]
